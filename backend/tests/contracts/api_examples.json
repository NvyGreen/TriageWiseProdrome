  "POST /overrides": {
    "method": "applyOverride(severityId, clinicianESI, reasonCode, note)",
    "valid_201": {
      "request": {
        "body": {
          "severity_id": 8837,
          "clinician_esi": 1,
          "reason_code": "clinical_judgment",
          "note": "Diaphoretic on exam; escalating to ESI-1."
        }
      },
      "response": {
        "status": 201,
        "body": {
          "override_id_INFERRED": 512,
          "severity_id": 8837,
          "system_esi": 2,
          "clinician_esi": 1,
          "queue_position_after": 1,
          "reprioritized": true
        }
      }
    },
    "invalid_400": {
      "_why": "Malformed override body / bad ESI value.",
      "request": {
        "body": {
          "severity_id": 8837,
          "clinician_esi": 9
        }
      },
      "response": {
        "status": 400,
        "body": {
          "error": {
            "code": "invalid_input",
            "message": "Malformed body, wrong types, missing required field (e.g. no chief complaint), out-of-range vital",
            "details": [
              {
                "field": "clinician_esi",
                "issue": "must be between 1 and 5"
              }
            ],
            "request_id": "req_01H9XYZ_o400"
          }
        }
      }
    },
    "not_found_404": {
      "_why": "Unknown severity_id (override targets a score that doesn't exist).",
      "request": {
        "body": {
          "severity_id": 999999,
          "clinician_esi": 2,
          "reason_code": "clinical_judgment"
        }
      },
      "response": {
        "status": 404,
        "body": {
          "error": {
            "code": "not_found",
            "message": "No severity record with that id.",
            "details": [
              {
                "field": "severity_id",
                "issue": "999999 does not exist"
              }
            ],
            "request_id": "req_01H9XYZ_o404"
          }
        }
      }
    },
    "conflict_409": {
      "_why": "Idempotency conflict on override retry.",
      "request": {
        "body": {
          "severity_id": 8837,
          "clinician_esi": 1,
          "reason_code": "clinical_judgment",
          "note": "duplicate submit"
        }
      },
      "response": {
        "status": 409,
        "body": {
          "error": {
            "code": "duplicate_request",
            "message": "Idempotency conflict — same intake POSTed twice (same Idempotency-Key, or identical intake within a short window)",
            "details": [
              {
                "field": "severity_id",
                "issue": "an identical override is already recorded"
              }
            ],
            "request_id": "req_01H9XYZ_o409"
          }
        }
      }
    }
  },
