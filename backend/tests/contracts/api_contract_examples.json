                "field": "severity_id",
                "issue": "999999 does not exist"
              }
            ],
            "request_id": "req_01H9XYZ_o404"
          }
        }
      }
    },
    "conflict_409": {
      "_why": "Idempotency conflict on override retry.",
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9OVR_ok01"
        },
        "body": {
          "severity_id": 8837,
          "clinician_esi": 1,
          "reason_code": "clinical_judgment",
          "note": "duplicate submit"
        }
      },
      "response": {
        "status": 409,
        "body": {
          "error": {
            "code": "duplicate_request",
            "message": "This override was already applied.",
            "details": [
              {
                "field": "severity_id",
                "issue": "an identical override is already recorded"
              }
            ],
            "request_id": "req_01H9XYZ_o409"
          }
        }
      }
