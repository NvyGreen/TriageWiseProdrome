{
  "_meta": {
    "title": "TriageWiseProdrome — API request/response examples",
    "source_of_truth": "API_Reference_v30.md",
    "purpose": "Test fixtures for endpoint shape/status assertions; doubles as the API contract doc.",
    "notes": [
      "Every route calls exactly one TriageService method (see endpoint_method_map).",
      "All errors use the consistent error envelope: { error: { code, message, details?, request_id } }.",
      "POST /patients accepts an Idempotency-Key header; a repeat with the same key returns the original result, a different intake colliding on the dedup window returns 409.",
      "Fields marked with a sibling key ending in _INFERRED are Claude's plausible guesses where v30 named the view-model but not the exact sub-fields — verify against the real schema and delete the _INFERRED markers once confirmed."
    ],
    "endpoint_method_map": {
      "POST /patients": "submitIntake(data)",
      "GET /queue": "getQueue()",
      "GET /patients/{id}": "getPatientDetail(patientId)",
      "PATCH /patients/{id}": "updatePatient(patientId, updates)",
      "POST /overrides": "applyOverride(severityId, clinicianESI, reasonCode, note)",
      "GET /metrics": "getMetrics()",
      "GET /reference/complaints": "getComplaintOptions()"
    }
  },
  "POST /patients": {
    "method": "submitIntake(data)",
    "valid_201": {
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_ab12cd34"
        },
        "body": {
          "name": "Jordan Ellis",
          "date_of_birth": "1958-03-14",
          "sex": "M",
          "chief_complaint": "cardiac",
          "symptoms": [
            "chest tightness",
            "left arm discomfort"
          ],
          "heart_rate": 96,
          "blood_pressure_systolic": 138,
          "blood_pressure_diastolic": 84,
          "respiration_rate": 18,
          "oxygen_saturation": 97,
          "temperature": 98.6,
          "pain_level": 6,
          "pregnancy_status": "none",
          "pre_existing_conditions": [
            "hypertension"
          ],
          "arrival_by_ambulance": false,
          "recent_ed_visit_72h": false,
          "injury_related": false
        }
      },
      "response": {
        "status": 201,
        "body": {
          "patient_id": 4021,
          "severity": {
            "severity_id": 8837,
            "esi_level": 2,
            "esi_band": 2,
            "severity_score": 6,
            "flag_tier": null,
            "data_completeness": "high"
          },
          "queue_placement": {
            "position": 3,
            "sort_key_INFERRED": [
              2,
              9999,
              "2026-07-14T10:22:00Z",
              8837
            ]
          }
        }
      }
    },
    "invalid_400": {
      "_why": "Malformed / wrong types / out-of-range vital. 'I can't read this request.'",
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_bad400"
        },
        "body": {
          "chief_complaint": "cardiac",
          "symptoms": [
            "chest tightness"
          ],
          "heart_rate": "ninety",
          "oxygen_saturation": 150,
          "pain_level": 15
        }
      },
      "response": {
        "status": 400,
        "body": {
          "error": {
            "code": "invalid_input",
            "message": "One or more fields are invalid.",
            "details": [
              {
                "field": "heart_rate",
                "issue": "must be a positive integer"
              },
              {
                "field": "oxygen_saturation",
                "issue": "must be between 0 and 100"
              },
              {
                "field": "pain_level",
                "issue": "must be between 0 and 10"
              }
            ],
            "request_id": "req_01H9XYZ_bad400"
          }
        }
      }
    },
    "missing_idempotency_key_400": {
      "_why": "Idempotency-Key header is required on POST; absent → 400.",
      "request": {
        "headers": {},
        "body": {
          "note": "valid body, but no Idempotency-Key header"
        }
      },
      "response": {
        "status": 400,
        "body": {
          "error": {
            "code": "invalid_input",
            "message": "Idempotency-Key header is required.",
            "details": [
              {
                "field": "Idempotency-Key",
                "issue": "required header is missing"
              }
            ],
            "request_id": "req_01H9XYZ_nohdr"
          }
        }
      }
    },
    "conflict_409": {
      "_why": "Same Idempotency-Key (or identical intake within the dedup window) POSTed twice.",
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_ab12cd34"
        },
        "body": {
          "note": "identical to valid_201 intake, retried"
        }
      },
      "response": {
        "status": 409,
        "body": {
          "error": {
            "code": "duplicate_request",
            "message": "This intake was already submitted.",
            "details": [
              {
                "field": "Idempotency-Key",
                "issue": "already used for a prior request"
              }
            ],
            "request_id": "req_01H9XYZ_dup"
          }
        }
      }
    },
    "unscoreable_422": {
      "_why": "Body is well-formed and complete, but no scoring rule can fire, so no severity can be produced. 'I read it fine, but it can't be scored.'",
      "_not_client_triggerable": "Every valid ChiefComplaint maps to a complaint rule with weight >= 1, so a well-formed POST always scores at least 1. This path is only reachable when the matching complaint rule is inactive or absent from scoring_rule. Test setup must deactivate the rule for this complaint (is_active = false) before sending the request; the body below is otherwise valid and would return 201 with the rule on.",
      "setup": {
        "deactivate_rules": [
          13
        ]
      },
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_unscore"
        },
        "body": {
          "name": "Alex Rivera",
          "date_of_birth": "1979-11-02",
          "sex": "F",
          "chief_complaint": "general",
          "symptoms": [],
          "heart_rate": 78,
          "blood_pressure_systolic": 118,
          "blood_pressure_diastolic": 76,
          "respiration_rate": 16,
          "oxygen_saturation": 98,
          "temperature": 98.4,
          "pain_level": 2,
          "pregnancy_status": "none",
          "pre_existing_conditions": [],
          "arrival_by_ambulance": false,
          "recent_ed_visit_72h": false,
          "injury_related": false,
          "source": "form"
        }
      },
      "response": {
        "status": 422,
        "body": {
          "error": {
            "code": "unscoreable",
            "message": "The intake is valid but cannot be scored.",
            "request_id": "req_01H9XYZ_unscore"
          }
        }
      }
    }
  },
