  "PATCH /intakes/{id}": {
    "method": "updatePatient(patientId, updates)",
    "_note": "Partial update (PATCH). Send only changed fields; others untouched. Recomputes severity + reorders queue (req 1.7).",
    "valid_200": {
      "_why": "Clinician updates pain_level (and optionally other vitals); severity + queue position recompute.",
      "request": {
        "path": "/intakes/4021",
        "body": {
          "pain_level": 9,
          "heart_rate": 104
        }
      },
      "response": {
        "status": 200,
        "body": {
          "patient_id": 4021,
          "severity": {
            "severity_id": 8840,
            "esi_level": 2,
            "severity_score": 7,
            "data_completeness": "high"
          },
          "queue_placement": {
            "position": 2,
            "reordered": true
          }
        }
      }
    },
    "invalid_400": {
      "_why": "Bad update value (e.g. pain out of range).",
      "request": {
        "path": "/intakes/4021",
        "body": {
          "pain_level": 15
        }
      },
      "response": {
        "status": 400,
        "body": {
          "error": {
            "code": "invalid_input",
            "message": "Update contains an invalid field.",
            "details": [
              {
                "field": "pain_level",
                "issue": "must be between 0 and 10"
              }
            ],
            "request_id": "req_01H9XYZ_u400"
          }
        }
      }
    },
    "not_found_404": {
      "_why": "Unknown patient_id — update targets a patient that doesn't exist.",
      "request": {
        "path": "/intakes/999999",
        "body": {
          "pain_level": 5
        }
      },
      "response": {
        "status": 404,
        "body": {
          "error": {
            "code": "not_found",
            "message": "No patient with that id.",
            "details": [
              {
                "field": "patient_id",
                "issue": "999999 does not exist"
              }
            ],
            "request_id": "req_01H9XYZ_u404"
          }
        }
      }
    },
    "unscoreable_422": {
      "_why": "Update is well-formed - at least one vital is present - but after re-scoring no rule can fire, so no severity can be produced.",
      "_not_client_triggerable": "IntakeUpdate only accepts the 8 vital/pain fields plus status - chief_complaint is not updatable. Clearing every scoreable vital still leaves the complaint rule firing (>= 1 point), and a body with no vitals at all is rejected as 400. So no valid PATCH body can reach this path. It is only reachable when the intake's complaint rule is inactive or absent from scoring_rule. Test setup must deactivate that rule; with the rule on, the body below returns 200.",
      "setup": {
        "deactivate_rules": [
          13
        ],
        "seeded_intake_complaint": "general"
      },
      "request": {
        "path": "/intakes/4021",
        "body": {
          "heart_rate": null,
          "blood_pressure_systolic": null,
          "oxygen_saturation": null,
          "respiration_rate": null,
          "pain_level": null,
          "temperature": 98.4
        }
      },
      "response": {
        "status": 422,
        "body": {
          "error": {
            "code": "unscoreable",
            "message": "The intake is valid but cannot be scored.",
            "request_id": "req_01H9XYZ_u422"
          }
        }
      }
    }
  },
