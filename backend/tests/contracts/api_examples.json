{
  "_meta": {
    "title": "TriageWiseProdrome — API request/response examples",
    "source_of_truth": "API_Reference_v30.md",
    "purpose": "Test fixtures for endpoint shape/status assertions; doubles as the API contract doc.",
    "notes": [
      "Every route calls exactly one TriageService method (see endpoint_method_map).",
      "All errors use the consistent error envelope: { error: { code, message, details?, request_id } }.",
      "POST /patients accepts an Idempotency-Key header; a repeat with the same key returns the original result, a different intake colliding on the dedup window returns 409.",
      "Fields marked with a sibling key ending in _INFERRED are Claude's plausible guesses where v30 named the view-model but not the exact sub-fields — verify against the real schema and delete the _INFERRED markers once confirmed.",
      "POST /patients body matches the IntakeCreate Pydantic model: single 'name' field, FLAT vitals (no nested 'vitals' object), no 'notes' field. Client does not send patient_id/intake_id/timestamps."
    ],
    "endpoint_method_map": {
      "POST /patients": "submitIntake(data)",
      "GET /queue": "getQueue()",
      "GET /patients/{id}": "getPatientDetail(patientId)",
      "POST /overrides": "applyOverride(severityId, clinicianESI, reasonCode, note)",
      "GET /metrics": "getMetrics()",
      "GET /reference/complaints": "getComplaintOptions()"
    }
  },
  "POST /patients": {
    "method": "submitIntake(data)",
    "valid_201": {
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_ab12cd34"
        },
        "body": {
          "name": "Jordan Ellis",
          "date_of_birth": "1958-03-14",
          "sex": "M",
          "chief_complaint": "chest_pain",
          "symptoms": [
            "chest tightness",
            "left arm discomfort"
          ],
          "heart_rate": 96,
          "blood_pressure_systolic": 138,
          "blood_pressure_diastolic": 84,
          "temperature": 98.6,
          "oxygen_saturation": 97,
          "respiration_rate": 18,
          "pain_level": 6,
          "blood_sugar": null,
          "pregnancy_status": "none",
          "pre_existing_conditions": [
            "hypertension"
          ],
          "arrival_by_ambulance": false,
          "recent_ed_visit_72h": false,
          "injury_related": false,
          "source": "form"
        }
      },
      "response": {
        "status": 201,
        "body": {
          "patient_id": 4021,
          "severity": {
            "severity_id": 8837,
            "esi_level": 2,
            "esi_band": 2,
            "severity_score": 6,
            "flag_tier": null,
            "data_completeness": "high"
          },
          "queue_placement": {
            "position": 3,
            "sort_key_INFERRED": [
              2,
              9999,
              "2026-07-14T10:22:00Z",
              8837
            ]
          }
        }
      }
    },
    "invalid_400": {
      "_why": "Malformed / wrong types / out-of-range vital. 'I can't read this request.'",
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_bad400"
        },
        "body": {
          "name": "Test Case",
          "date_of_birth": "1970-01-01",
          "sex": "M",
          "chief_complaint": "chest_pain",
          "symptoms": [
            "chest tightness"
          ],
          "heart_rate": "ninety",
          "oxygen_saturation": 150,
          "pain_level": 15
        }
      },
      "response": {
        "status": 400,
        "body": {
          "error": {
            "code": "invalid_input",
            "message": "Malformed body, wrong types, missing required field (e.g. no chief complaint), out-of-range vital",
            "details": [
              {
                "field": "heart_rate",
                "issue": "must be a positive integer"
              },
              {
                "field": "oxygen_saturation",
                "issue": "must be between 0 and 100"
              },
              {
                "field": "pain_level",
                "issue": "must be between 0 and 10"
              }
            ],
            "request_id": "req_01H9XYZ_bad400"
          }
        }
      }
    },
    "conflict_409": {
      "_why": "Same Idempotency-Key (or identical intake within the dedup window) POSTed twice.",
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_ab12cd34"
        },
        "body": {
          "_note": "identical to valid_201 intake, retried with same Idempotency-Key"
        }
      },
      "response": {
        "status": 409,
        "body": {
          "error": {
            "code": "duplicate_request",
            "message": "Idempotency conflict — same intake POSTed twice (same Idempotency-Key, or identical intake within a short window)",
            "details": [
              {
                "field": "Idempotency-Key",
                "issue": "already used for a prior request"
              }
            ],
            "request_id": "req_01H9XYZ_dup"
          }
        }
      }
    },
    "unscoreable_422": {
      "_why": "Well-formed body, but nothing can be scored — no chief-complaint mapping or too little data for any rule to fire. 'I read it fine, but it can't be scored.'",
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9XYZ_unscore"
        },
        "body": {
          "name": "Minimal Case",
          "date_of_birth": "1990-05-05",
          "sex": "unknown",
          "chief_complaint": "other_general",
          "symptoms": []
        }
      },
      "response": {
        "status": 422,
        "body": {
          "error": {
            "code": "unscoreable",
            "message": "Body is well-formed but cannot be scored — e.g. no chief complaint mapping, or so much missing data that no rule can fire",
            "details": [
              {
                "field": "vitals",
                "issue": "no vitals present and complaint has no standalone weight sufficient to score"
              }
            ],
            "request_id": "req_01H9XYZ_unscore"
          }
        }
      }
    }
  },
