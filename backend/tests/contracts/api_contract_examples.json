        }
      }
    },
    "not_found_404": {
      "_why": "Unknown severity_id (override targets a score that doesn't exist).",
      "request": {
        "headers": {
          "Idempotency-Key": "req_01H9OVR_nf"
        },
        "body": {
          "severity_id": 999999,
          "clinician_esi": 2,
